# ---------------------------------------------------------------------------
# AI Werewolf — environment template
#   1. cp .env.example .env
#   2. fill in the secrets below (DOUBAO + DEEPSEEK are project-issued)
#   3. (optional) point DATABASE_URL at your Postgres; otherwise SQLite is used
# ---------------------------------------------------------------------------

# Primary LLM: 方舟 doubao-seed 2.0 pro & code (项目组提供)
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=Doubao-Seed-2.0-pro
# Optional explicit endpoint id (ep-xxxx) when running via the Ark gateway
DOUBAO_ENDPOINT=ep-20260514115354-k4jz4
# Optional Ark-compatible aliases for local Claude-style launch configs
ARK_API_KEY=
ARK_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=

# Fallback: DeepSeek v4 Flash
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Local OpenAI-compatible Mimo endpoint (optional)
# Example base URL should point to the API prefix before /chat/completions.
MIMO_BASE_URL=
MIMO_MODEL=mimo-local
MIMO_API_KEY=local

# Active LLM provider: "doubao" | "deepseek" | "mimo" | "fake"
LLM_PROVIDER=doubao

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Leave blank to fall back to SQLite at data/werewolf.db (dev only).
# Local docker postgres (matches docker-compose.yml / Makefile):
DATABASE_URL=postgresql+psycopg2://werewolf:your_password_here@127.0.0.1:5433/werewolf

# Inside docker-compose, the backend reaches Postgres at host "postgres":
# DATABASE_URL=postgresql+psycopg2://werewolf:your_password_here@postgres:5432/werewolf

# Other LLM APIs (add as needed)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
