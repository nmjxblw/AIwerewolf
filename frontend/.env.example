# Frontend env template — copy to .env.local and adjust
#
#   cp frontend/.env.example frontend/.env.local
#
# In dev: backend runs on http://localhost:8000 by default.
# In docker compose: leave empty so the browser uses the same origin (reverse proxy).
BACKEND_ORIGIN="http://127.0.0.1:8001"
NEXT_PUBLIC_BACKEND_ORIGIN=http://localhost:8001
