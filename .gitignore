# =====================================
# AIwerewolf - repository hygiene rules
# =====================================

# ---- OS / editor ----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*.tmp

# ---- Python cache / tooling ----
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.hypothesis/

# ---- Virtual envs / local runtimes ----
.venv/
venv/
env/
ENV/
.pixi/
.pdm-python

# ---- Local secrets / credentials ----
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
*.secrets
.pypirc
.streamlit/secrets.toml

# ---- Python packaging/build outputs ----
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# ---- Frontend build artifacts ----
node_modules/
frontend/.next/
frontend/.next*/
.next/
.next*/
tsconfig.tsbuildinfo
*.tsbuildinfo

# ---- Logs / reports / local runtime outputs ----
*.log
logs/
*.out
*.err
*.pid
coverage.xml
nosetests.xml

# ---- Local DB / caches / simulator outputs ----
*.db
*.sqlite
*.sqlite3
*.sqlite3-*
search_simulator_cache.sqlite3
endings.json
search_tree.png

# ---- Heavy local data / experiment outputs ----
data/
models/
outputs/
references/
prototype/
wolf/

# ---- Binary/media artifacts that should not be committed ----
*.zip
*.7z
*.tar
*.gz
*.rar
*.pdf
*.pptx
*.mp4
*.mov
*.avi
*.wav
*.mp3
*.png
*.jpg
*.jpeg
*.gif

# ---- Keep code/docs assets when intentionally versioned ----
!docs/**/*.svg
!docs/**/*.html

# ---- Local helper files ----
packaging_probe.txt
